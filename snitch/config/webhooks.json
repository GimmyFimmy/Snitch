{
  "url": "https://api.github.com/repos/USERNAME/REPOSITORY/hooks",
  "add": {
    "headers": {
      "Authorization": "token {github_token}",
      "Accept": "application/vnd.github.v3+json"
    },
    "payload": {
      "name": "web",
      "active": true,
      "events": [
        "*"
      ],
      "config": {
        "url": "{payload_url}",
        "content_type": "json"
      }
    }
  },
  "remove": {
    "headers": {
      "Authorization": "token {github_token}"
    }
  }
}